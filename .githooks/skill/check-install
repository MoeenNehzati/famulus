#!/usr/bin/env bash
# End-to-end install verification: for each platform CLI found on PATH (codex, claude, …),
# runs the corresponding tests/test_*_install.sh to confirm the plugin installs cleanly and
# all skills are visible and individually invokable after installation.
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
failed=0
for install_test in "$repo_root/tests"/test_*_install.sh; do
    [[ -f "$install_test" ]] || continue
    basename="${install_test##*/}"
    platform="${basename#test_}"
    platform="${platform%_install.sh}"
    if command -v "$platform" &>/dev/null; then
        echo "[$platform detected] Running $basename"
        bash "$install_test" || failed=1
    fi
done
exit $failed
