#!/usr/bin/env bash
set -uo pipefail

hook_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! git symbolic-ref HEAD >/dev/null 2>&1; then
    echo "error: repository is in detached HEAD state." >&2
    echo "Check out a named branch before committing:" >&2
    echo "  git checkout master" >&2
    exit 1
fi

failed=0
"${hook_dir}/git/check-not-detached" || failed=1
"${hook_dir}/skill/check-names" || failed=1
"${hook_dir}/skill/check-dependencies" || failed=1
"${hook_dir}/skill/check-metadata" || failed=1
"${hook_dir}/skill/check-platform-neutral" || failed=1
"${hook_dir}/skill/check-install" || failed=1
exit $failed
