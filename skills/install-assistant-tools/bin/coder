#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: coder [--claude|--codex] [-h|--help] [args...]

Launch the coder agent from the current directory.

  --claude      Use Claude (claude --agent coder)
  --codex       Use Codex (codex --profile coder)
  -h, --help    Show this help

The default backend is \$CODER_DEFAULT, then \$ASSISTANT_DEFAULT.
Falls back to claude if neither is set.
EOF
}

backend="${CODER_DEFAULT:-${ASSISTANT_DEFAULT:-claude}}"

case "${1:-}" in
  --claude)  backend=claude; shift ;;
  --codex)   backend=codex;  shift ;;
  -h|--help) usage; exit 0 ;;
esac

case "$backend" in
  claude) exec claude --agent coder "$@" ;;
  codex)  exec codex --profile coder "$@" ;;
  *)      echo "coder: unknown backend '$backend' - set CODER_DEFAULT or ASSISTANT_DEFAULT to claude or codex" >&2; exit 1 ;;
esac
