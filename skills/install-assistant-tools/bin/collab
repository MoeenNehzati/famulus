#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: collab [--claude|--codex] [-h|--help] [args...]

Launch the collab agent from the current directory.

  --claude      Use Claude (claude --agent collab)
  --codex       Use Codex (codex --profile collab)
  -h, --help    Show this help

The default backend is \$COLLAB_DEFAULT, then \$ASSISTANT_DEFAULT.
Falls back to claude if neither is set.
EOF
}

backend="${COLLAB_DEFAULT:-${ASSISTANT_DEFAULT:-claude}}"

case "${1:-}" in
  --claude)  backend=claude; shift ;;
  --codex)   backend=codex;  shift ;;
  -h|--help) usage; exit 0 ;;
esac

case "$backend" in
  claude) exec claude --agent collab "$@" ;;
  codex)  exec codex --profile collab "$@" ;;
  *)      echo "collab: unknown backend '$backend' - set COLLAB_DEFAULT or ASSISTANT_DEFAULT to claude or codex" >&2; exit 1 ;;
esac
