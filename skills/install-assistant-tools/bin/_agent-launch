#!/usr/bin/env bash
# _agent-launch — shared launcher for assistant/collab/coauthor.
# Not intended to be called directly.
#
# Usage: _agent-launch <agent> <default-backend> [flags...] [args...]
set -euo pipefail

agent="${1:?_agent-launch: agent name required}"
backend="${2:?_agent-launch: default backend required}"
shift 2

usage() {
  cat <<EOF
Usage: $agent [-l|--local] [--claude|--codex] [-h|--help] [args...]

  -l, --local   Run in current directory instead of \$AI/workers/$agent
  --claude      Use Claude (claude --agent $agent)
  --codex       Use Codex (codex --profile $agent)
  -h, --help    Show this help

Default backend: $backend
Working directory: \$AI/workers/$agent (skip with -l/--local).
Claude settings: \$CLAUDE_HOME/${agent}_claude_setting.json
EOF
}

use_local=false

case "${1:-}" in
  -l|--local) use_local=true; shift ;;
esac

case "${1:-}" in
  --claude)  backend=claude; shift ;;
  --codex)   backend=codex;  shift ;;
  -h|--help) usage; exit 0 ;;
esac

if [[ "$use_local" == false ]]; then
  cd "${AI:?AI is not set — re-run the installer}/workers/$agent" || exit 1
fi

claude_home="${CLAUDE_HOME:-$HOME/.claude}"

case "$backend" in
  claude) exec claude --agent "$agent" --settings "$claude_home/${agent}_claude_setting.json" "$@" ;;
  codex)  exec codex --profile "$agent" "$@" ;;
  *)      echo "$agent: unknown backend '$backend'" >&2; exit 1 ;;
esac
