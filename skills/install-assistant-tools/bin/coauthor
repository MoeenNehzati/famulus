#!/usr/bin/env python3
"""Launcher for the 'coauthor' agent.

Backend priority: $COAUTHOR_DEFAULT > $ASSISTANT_DEFAULT > 'claude'.
See bin/assistant for notes on adding new agents.
"""
import os, sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
import _agent_launch

_agent_launch.launch(
    agent="coauthor",
    default_backend=os.environ.get("COAUTHOR_DEFAULT", os.environ.get("ASSISTANT_DEFAULT", "claude")),
    args=sys.argv[1:],
)
