{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "$ref": "entry.json"
    }
  ],
  "required": [
    "state",
    "deadline"
  ],
  "properties": {
    "state": {
      "type": "string"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "location": {
      "type": "string"
    }
  }
}
