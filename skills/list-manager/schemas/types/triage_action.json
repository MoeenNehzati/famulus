{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "$ref": "task_entry.json"
    }
  ],
  "type": "object",
  "required": [
    "id",
    "title",
    "created",
    "state",
    "deadline"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{6}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "description": {
      "type": "string"
    },
    "children": {
      "type": "array",
      "items": {
        "$ref": "triage_action.json"
      }
    },
    "state": {
      "enum": [
        "undecided",
        "accepted",
        "rejected"
      ]
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "location": {
      "type": "string"
    },
    "modified": {
      "type": "string",
      "format": "date",
      "description": "Auto-stamped to today by `lists.py update` whenever any field on this entry changes -- not user-set."
    },
    "completed": {
      "type": "string",
      "format": "date",
      "description": "Auto-stamped to today the first time a patch sets state to accepted/rejected -- not user-set (unless the patch explicitly provides it). Never overwritten by later, unrelated edits."
    }
  },
  "additionalProperties": false
}
