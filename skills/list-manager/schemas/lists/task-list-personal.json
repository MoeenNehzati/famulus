{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Constraint for Personal domain subcategory arrays. Requires exactly: Replies, Payments, Reading, Writing, Tasks, Misc, Shop.",
  "type": "array",
  "uniqueItems": true,
  "minItems": 7,
  "maxItems": 7,
  "items": {
    "type": "object",
    "required": ["name"],
    "properties": {
      "name": {
        "enum": ["Replies", "Payments", "Reading", "Writing", "Tasks", "Misc", "Shop"]
      }
    }
  },
  "allOf": [
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Replies"  } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Payments" } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Reading"  } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Writing"  } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Tasks"    } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Misc"     } } } },
    { "contains": { "required": ["name"], "properties": { "name": { "const": "Shop"     } } } }
  ]
}
