{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "skill.schema.json",
  "title": "Typed Skill Root Blueprint",
  "description": "Canonical graph root for one skill. It owns skill-local metadata, its default LLM interface, and pointers to additional interface blueprints.",
  "type": "object",
  "required": ["schema_version", "node_type", "id", "category", "role", "kind", "gateway", "content", "default_interface", "interfaces"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schemaVersion", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": 3}, "doc": {"authoring": ["Use typed blueprint schema version 3."]}, "related_validation_rules": ["schema-shape"]}},
    "node_type": {"const": "skill", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "skill"}, "doc": {"authoring": ["Identify this canonical file as the skill graph root."]}, "related_validation_rules": ["schema-shape"]}},
    "id": {"$ref": "common.schema.json#/definitions/skillId", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "example-skill"}, "doc": {"authoring": ["Use the exact skill directory name."]}, "related_validation_rules": ["canonical-id", "root-directory-id"]}},
    "category": {"$ref": "legacy-skill.schema.json#/properties/category", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "development-assistant"}, "doc": {"authoring": ["Choose the narrowest valid skill taxonomy category."]}, "related_validation_rules": ["schema-shape"]}},
    "role": {"$ref": "legacy-skill.schema.json#/definitions/skillRole", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "automation"}, "doc": {"authoring": ["Describe the skill's operating role."]}, "related_validation_rules": ["schema-shape"]}},
    "kind": {"$ref": "legacy-skill.schema.json#/definitions/skillKind", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "tool"}, "doc": {"authoring": ["Describe the skill's implementation kind."]}, "related_validation_rules": ["schema-shape"]}},
    "gateway": {"$ref": "common.schema.json#/definitions/skillGateway", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": {"kind": "instruction-file", "path": "SKILL.md"}}, "doc": {"authoring": ["Use SKILL.md as the skill root and embedded default-interface gateway."]}, "related_validation_rules": ["gateway-file", "content-files"]}},
    "content": {"$ref": "common.schema.json#/definitions/contentPatterns", "type": "array", "minItems": 1, "uniqueItems": true, "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": ["SKILL\\.md"]}, "doc": {"authoring": ["Match every file exclusively owned by the skill root; the gateway must match."]}, "related_validation_rules": ["content-files", "content-exclusive", "commit-backed-stamp"]}},
    "skill_interface": {"$ref": "legacy-skill.schema.json#/properties/skill_interface", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": true, "example": {"inputs": ["User request that triggers this skill."], "outputs": ["Primary user-visible result."], "side_effects": []}}, "doc": {"authoring": ["Describe skill-level inputs, outputs, and side effects only."]}, "related_validation_rules": ["schema-shape"]}},
    "suggested_permissions": {"$ref": "legacy-skill.schema.json#/properties/suggested_permissions", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": true, "example": {"bash": [{"command": ["dispatcher"], "args_prefix": ["--caller-skill", "example-skill"], "reason": "Invoke the skill's exported machine interfaces."}], "network": []}}, "doc": {"authoring": ["Declare suggested host permissions without duplicating interface-local behavior."]}, "related_validation_rules": ["schema-shape"]}},
    "default_interface": {"$ref": "default-llm-interface.schema.json", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true}, "doc": {"authoring": ["Define the canonical <skill>.llm.default contract inline; it uses the root SKILL.md gateway and content."]}, "related_validation_rules": ["default-interface", "gateway-file"]}},
    "interfaces": {
      "type": "array",
      "minItems": 0,
      "uniqueItems": true,
      "items": {"$ref": "common.schema.json#/definitions/interfaceEdge"},
      "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": [{"interface": "example-skill.machine.run", "version": 1, "blueprint": {"base": "skill-root", "path": "_rtx/._runner.py.blueprint.yaml"}}]}, "doc": {"authoring": ["Point to each non-default interface's hidden sidecar; llm.default is always inline."]}, "related_validation_rules": ["root-interface-edge", "version-pin", "gateway-file", "relationship-edge"]}
    }
  },
  "allOf": [
    {
      "properties": {
        "interfaces": {
          "not": {"contains": {"type": "object", "required": ["interface"], "properties": {"interface": {"pattern": "\\.llm\\.default$"}}}}
        }
      }
    }
  ],
  "x-famulus": {
    "audit_hash": "include",
    "gateway_policy": "required-skill-md",
    "generated_skill_md_blocks": {
      "contract": "Generated SKILL.md blueprint contract block records the canonical root identity and schema version.",
      "interfaces": "Generated SKILL.md blueprint interface block records each declared canonical interface ID, version, and sidecar path."
    }
  }
}
