{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "machine-interface.schema.json",
  "title": "Typed Machine Interface Blueprint",
  "description": "Complete contract for one dispatcher-callable machine interface. Binding kind selects Python or direct command-file execution without changing the public machine namespace.",
  "type": "object",
  "required": ["schema_version", "blueprint_type", "id", "version", "description", "binding", "platform_support", "dependencies", "behavior_sources", "direct_io", "owns_filesystem"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schemaVersion", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": 2}, "doc": {"authoring": ["Use typed blueprint schema version 2."]}, "related_validation_rules": ["schema-shape"]}},
    "blueprint_type": {"const": "machine-interface", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "machine-interface"}, "doc": {"authoring": ["Identify this file as one machine interface contract."]}, "related_validation_rules": ["schema-shape"]}},
    "id": {"$ref": "common.schema.json#/definitions/machineInterfaceId", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "demo-skill.machine.run"}, "doc": {"authoring": ["Use skill.machine.local-name for the public dispatcher ID."]}, "related_validation_rules": ["canonical-id"]}},
    "version": {"$ref": "common.schema.json#/definitions/interfaceVersion", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": 1}, "doc": {"authoring": ["Increment when caller-visible arguments, outputs, or behavior change."]}, "related_validation_rules": ["version-pin"]}},
    "description": {"type": "string", "minLength": 1, "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "Run the operation."}, "doc": {"authoring": ["Summarize this machine operation in one concrete sentence."]}, "related_validation_rules": ["schema-shape"]}},
    "usage": {"type": "string", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["Show the caller-visible argument form, or an empty string for no arguments."]}, "related_validation_rules": ["schema-shape"]}},
    "binding": {"oneOf": [{"$ref": "common.schema.json#/definitions/pythonEntrypointBinding"}, {"$ref": "common.schema.json#/definitions/commandFileBinding"}], "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": {"kind": "python-entrypoint", "path": "_rtx/_runner.py", "symbol": "Interface", "args_prefix": []}}, "doc": {"authoring": ["Bind one Python entrypoint file under _rtx or one directly executed command file under _cx; never embed a shell command string."]}, "related_validation_rules": ["machine-binding-kind", "file-binding"]}},
    "local_hash_inputs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}, "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["List exact additional files owned by this node whose bytes affect its local behavior. Child-node bindings do not belong here."]}, "related_validation_rules": ["file-binding", "commit-backed-stamp"]}},
    "patterns": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/definitions/pattern"}, "description": "Dispatcher argument grammar only; matching does not prove downstream resource confinement.", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["Constrain dispatcher argv shapes only; patterns do not enforce downstream subsystem scope."]}, "related_validation_rules": ["dispatcher-argv-pattern"]}},
    "allow_all_skills": {"type": "boolean", "default": false, "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["Set true only when every skill may call this interface."]}, "related_validation_rules": ["access-control"]}},
    "allowed_callers": {"$ref": "common.schema.json#/definitions/allowedCallers", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["List exact skill IDs permitted to call this interface."]}, "related_validation_rules": ["access-control"]}},
    "platform_support": {"$ref": "common.schema.json#/definitions/platformSupport", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": {"linux": true, "macos": true, "windows": true}}, "doc": {"authoring": ["State support for Linux, macOS, and Windows explicitly."]}, "related_validation_rules": ["runtime-dependency"]}},
    "dependencies": {"$ref": "common.schema.json#/definitions/runtimeDependencies", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": []}, "doc": {"authoring": ["Declare every non-stdlib runtime dependency and use its platform map to state where that dependency applies."]}, "related_validation_rules": ["runtime-dependency"]}},
    "uses_interfaces": {"$ref": "common.schema.json#/definitions/usedMachineInterfaceList", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["Declare version-pinned machine interfaces directly called or orchestrated by this interface."]}, "related_validation_rules": ["relationship-edge", "version-pin", "access-control"]}},
    "behavior_sources": {"$ref": "common.schema.json#/definitions/behaviorSourceEdgeList", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": []}, "doc": {"authoring": ["Point to behavior sources used by this interface and state the consumer-local reason."]}, "related_validation_rules": ["behavior-source-edge", "version-pin", "file-binding"]}},
    "direct_io": {"$ref": "common.schema.json#/definitions/directIo", "x-famulus": {"field_status": "required", "audit_hash": "exclude", "template": {"include": true, "example": {"reads": [], "writes": [], "network": []}}, "doc": {"authoring": ["Describe immediate semantic IO; this does not prove subsystem access confinement."]}, "related_validation_rules": ["direct-io-description"]}},
    "owns_filesystem": {"$ref": "common.schema.json#/definitions/filesystemOwnershipList", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": []}, "doc": {"authoring": ["Declare files for which this machine interface is the writer authority."]}, "related_validation_rules": ["filesystem-ownership"]}}
  },
  "allOf": [{"$ref": "legacy-skill.schema.json#/definitions/allowAllSkillsConstraint"}],
  "x-famulus": {"audit_hash": "include-except-direct-io", "binding_policy": "regular-file"}
}
