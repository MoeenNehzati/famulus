{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "behavior-source.schema.json",
  "title": "Typed Behavior Source Blueprint",
  "description": "Intrinsic metadata and source-to-source edges for one behavior-shaping file.",
  "type": "object",
  "required": ["schema_version", "node_type", "id", "version", "description", "gateway", "content", "semantic_type", "format", "uses_behavior_sources"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"$ref": "common.schema.json#/definitions/schemaVersion", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": 3}, "doc": {"authoring": ["Use typed blueprint schema version 3."]}, "related_validation_rules": ["schema-shape"]}},
    "node_type": {"const": "behavior-source", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "behavior-source"}, "doc": {"authoring": ["Identify this file as one behavior-source contract."]}, "related_validation_rules": ["schema-shape"]}},
    "id": {"$ref": "common.schema.json#/definitions/behaviorSourceId", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "demo-skill.source.policy"}, "doc": {"authoring": ["Use skill.source.local-name for the canonical source ID."]}, "related_validation_rules": ["canonical-id"]}},
    "version": {"$ref": "common.schema.json#/definitions/interfaceVersion", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": 1}, "doc": {"authoring": ["Increment when the behavior-source contract changes."]}, "related_validation_rules": ["version-pin"]}},
    "description": {"type": "string", "minLength": 1, "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "Defines policy for the interface."}, "doc": {"authoring": ["Describe the source's intrinsic function, not a consumer's reason for using it."]}, "related_validation_rules": ["schema-shape"]}},
    "gateway": {"$ref": "common.schema.json#/definitions/behaviorSourceGateway", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": {"kind": "file", "path": "references/policy.md"}}, "doc": {"authoring": ["Name the primary existing file for this behavior-source artifact."]}, "related_validation_rules": ["gateway-file", "content-files"]}},
    "content": {"$ref": "common.schema.json#/definitions/contentPatterns", "type": "array", "minItems": 1, "uniqueItems": true, "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": ["references/policy\\.md"]}, "doc": {"authoring": ["Match every file in the semantically coherent artifact owned by this node; the gateway must match."]}, "related_validation_rules": ["content-files", "content-exclusive", "commit-backed-stamp"]}},
    "semantic_type": {"$ref": "common.schema.json#/definitions/semanticType", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "policy"}, "doc": {"authoring": ["Classify the semantic role of the complete behavior-source artifact, not its subject matter or representation."]}, "related_validation_rules": ["semantic-type"]}},
    "format": {"$ref": "common.schema.json#/definitions/metadataFormat", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": "markdown"}, "doc": {"authoring": ["Declare the bound file's concrete format."]}, "related_validation_rules": ["schema-shape"]}},
    "uses_behavior_sources": {"$ref": "common.schema.json#/definitions/behaviorSourceEdgeList", "x-famulus": {"field_status": "required", "audit_hash": "include", "template": {"include": true, "example": []}, "doc": {"authoring": ["Declare version-pinned downstream behavior sources and the local reason for each edge."]}, "related_validation_rules": ["behavior-source-edge", "version-pin", "gateway-file"]}},
    "uses_interfaces": {"$ref": "common.schema.json#/definitions/usedInterfaceList", "x-famulus": {"field_status": "optional", "audit_hash": "include", "template": {"include": false}, "doc": {"authoring": ["Declare every canonical interface named or orchestrated by this behavior source."]}, "related_validation_rules": ["relationship-edge", "version-pin", "interface-body-use"]}}
  },
  "x-famulus": {"audit_hash": "include", "gateway_policy": "regular-file", "allowed_edge_types": ["behavior-source", "interface"]}
}
