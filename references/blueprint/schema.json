{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Blueprint Schema",
  "description": "Schema for blueprint.yaml files that define skill contracts, dependencies, and interfaces.",
  "type": "object",
  "required": ["category", "role", "kind", "interfaces"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "research-assistant",
        "general-assistant",
        "productivity-general-assistant",
        "workflow-general-assistant",
        "development-assistant",
        "skill-making-development-assistant",
        "coding-development-assistant",
        "system-assistant"
      ]
    },
    "role": {
      "$ref": "#/definitions/skillRole"
    },
    "kind": {
      "$ref": "#/definitions/skillKind"
    },
    "cross_platform": {
      "type": "boolean",
      "default": true
    },
    "skill_interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suggested_permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bash": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "reason"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              },
              "args_prefix": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "reason"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": ["web_search", "web_fetch"]
              },
              "domains": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "interfaces": {
      "type": "object",
      "required": ["llm"],
      "additionalProperties": false,
      "properties": {
        "machine": {
          "$ref": "#/definitions/machineInterfaceMap"
        },
        "llm": {
          "$ref": "#/definitions/llmInterfaceMap"
        }
      }
    }
  },
  "definitions": {
    "skillRole": {
      "type": "string",
      "description": "Primary user-facing domain the skill serves.",
      "enum": [
        "productivity",
        "research-writing",
        "math-reasoning",
        "document-processing",
        "development-assistant",
        "system-operations",
        "integration",
        "meta-skill",
        "automation",
        "mode"
      ]
    },
    "skillKind": {
      "type": "string",
      "description": "Primary shape of help the skill provides.",
      "enum": [
        "workflow",
        "tool",
        "reviewer",
        "auditor",
        "generator",
        "installer",
        "planner",
        "client",
        "storage",
        "scheduler",
        "scaffold",
        "guide",
        "mode",
        "diagnostic",
        "orchestrator",
        "triager",
        "converter",
        "renderer",
        "builder",
        "syncer",
        "setup",
        "state-manager",
        "analyzer",
        "maintenance"
      ]
    },
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+$"
    },
    "interfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "canonicalInterfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+\\.(machine|llm)\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "machineInterfaceMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/interfaceName"
      },
      "additionalProperties": {
        "$ref": "#/definitions/machineInterface"
      }
    },
    "llmInterfaceMap": {
      "type": "object",
      "required": ["default"],
      "propertyNames": {
        "$ref": "#/definitions/interfaceName"
      },
      "additionalProperties": {
        "$ref": "#/definitions/llmInterface"
      }
    },
    "machineInterface": {
      "type": "object",
      "required": ["version", "platform_support", "invocation", "dependencies", "direct_io", "owns_filesystem"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "$ref": "#/definitions/interfaceVersion"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "usage": {
          "type": "string"
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/pattern"
          }
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/skillName"
          },
          "default": []
        },
        "platform_support": {
          "$ref": "#/definitions/platformSupport"
        },
        "invocation": {
          "$ref": "#/definitions/invocation"
        },
        "dependencies": {
          "$ref": "#/definitions/runtimeDependencies"
        },
        "uses_interfaces": {
          "$ref": "#/definitions/usedMachineInterfaceList"
        },
        "direct_io": {
          "$ref": "#/definitions/directIo"
        },
        "owns_filesystem": {
          "$ref": "#/definitions/filesystemOwnershipList"
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "runtimeDependencies": {
      "type": "array",
      "description": "Required runtime packages or executables for this machine interface. Use [] when the interface has no non-stdlib runtime dependencies.",
      "items": {
        "$ref": "#/definitions/runtimeDependency"
      },
      "uniqueItems": true
    },
    "runtimeDependency": {
      "type": "object",
      "required": ["kind", "name", "version", "platforms", "reason"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/runtimeDependencyKind"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.+\\-\\[\\]]*$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "platforms": {
          "$ref": "#/definitions/platformSupport"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtimeDependencyKind": {
      "type": "string",
      "enum": [
        "python-package",
        "binary",
        "system-service",
        "system-library",
        "external-application",
        "runtime",
        "model-data"
      ]
    },
    "platformSupport": {
      "type": "object",
      "description": "Explicit operating-system support flags. Each boolean must be present so unsupported platforms are represented deliberately.",
      "required": ["linux", "macos", "windows"],
      "additionalProperties": false,
      "properties": {
        "linux": {
          "type": "boolean"
        },
        "macos": {
          "type": "boolean"
        },
        "windows": {
          "type": "boolean"
        }
      }
    },
    "llmInterface": {
      "type": "object",
      "required": ["version", "description", "behavior_sources", "direct_io", "owns_filesystem"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "$ref": "#/definitions/interfaceVersion"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "binding": {
          "$ref": "#/definitions/llmBinding"
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/skillName"
          },
          "default": []
        },
        "routing_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "uses_interfaces": {
          "$ref": "#/definitions/usedInterfaceList"
        },
        "behavior_sources": {
          "$ref": "#/definitions/behaviorSourceList"
        },
        "direct_io": {
          "$ref": "#/definitions/directIo"
        },
        "owns_filesystem": {
          "$ref": "#/definitions/filesystemOwnershipList"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["binding"]
            },
            {
              "required": ["file"]
            }
          ]
        },
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "llmBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "path"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "skill_file"
            },
            "path": {
              "const": "SKILL.md"
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "markdown_file"
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/).+"
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "uri"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "uri"
            },
            "uri": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:.*$"
            }
          }
        }
      ]
    },
    "interfaceVersion": {
      "type": "integer",
      "minimum": 1
    },
    "usedInterfaceList": {
      "type": "array",
      "description": "Version-pinned canonical interfaces this interface may use or orchestrate. These interface hashes are included recursively in this interface's audit hash.",
      "items": {
        "$ref": "#/definitions/usedInterface"
      },
      "uniqueItems": true
    },
    "usedMachineInterfaceList": {
      "type": "array",
      "description": "Version-pinned canonical machine interfaces this machine interface may use or orchestrate.",
      "items": {
        "$ref": "#/definitions/usedMachineInterface"
      },
      "uniqueItems": true
    },
    "usedInterface": {
      "type": "object",
      "required": ["interface", "version"],
      "additionalProperties": false,
      "properties": {
        "interface": {
          "$ref": "#/definitions/canonicalInterfaceName"
        },
        "version": {
          "$ref": "#/definitions/interfaceVersion"
        }
      }
    },
    "usedMachineInterface": {
      "type": "object",
      "required": ["interface", "version"],
      "additionalProperties": false,
      "properties": {
        "interface": {
          "$ref": "#/definitions/canonicalMachineInterfaceName"
        },
        "version": {
          "$ref": "#/definitions/interfaceVersion"
        }
      }
    },
    "canonicalMachineInterfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+\\.machine\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "behaviorSourceList": {
      "type": "array",
      "description": "Non-code files or roots read by this interface that can influence behavior, such as schemas, templates, policy files, prompt markdown, examples, or parser tables. Python imports and dispatch targets are discovered mechanically and must not be duplicated here.",
      "items": {
        "$ref": "#/definitions/behaviorSource"
      },
      "uniqueItems": true
    },
    "behaviorSource": {
      "type": "object",
      "required": ["path", "content", "format", "reason"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        "content": {
          "$ref": "#/definitions/metadataContent"
        },
        "format": {
          "$ref": "#/definitions/metadataFormat"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "directEffectList": {
      "type": "array",
      "description": "Deprecated compatibility definition. Do not use in blueprint interfaces.",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
      },
      "uniqueItems": true
    },
    "directIo": {
      "type": "object",
      "description": "Immediate semantic IO for this interface only. Transitive IO is generated from uses_interfaces.",
      "required": ["reads", "writes", "network"],
      "additionalProperties": false,
      "properties": {
        "reads": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/directIoEntry"
          }
        },
        "writes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/directIoEntry"
          }
        },
        "network": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/directIoEntry"
          }
        }
      }
    },
    "directIoEntry": {
      "type": "object",
      "required": ["medium", "access", "content", "sensitivity"],
      "additionalProperties": false,
      "properties": {
        "medium": {
          "$ref": "#/definitions/metadataMedium"
        },
        "access": {
          "$ref": "#/definitions/metadataAccess"
        },
        "system": {
          "$ref": "#/definitions/metadataSystem"
        },
        "content": {
          "$ref": "#/definitions/metadataContent"
        },
        "format": {
          "$ref": "#/definitions/metadataFormat"
        },
        "auth": {
          "$ref": "#/definitions/metadataAuthRequirement"
        },
        "sensitivity": {
          "$ref": "#/definitions/metadataSensitivity"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "filesystemOwnershipList": {
      "type": "array",
      "description": "Filesystem paths this interface owns. Only the owner may write matching paths; only the owner and allowed_readers may read them.",
      "items": {
        "$ref": "#/definitions/filesystemOwnership"
      },
      "uniqueItems": true
    },
    "filesystemOwnership": {
      "type": "object",
      "required": ["match", "path", "allowed_readers"],
      "additionalProperties": false,
      "properties": {
        "match": {
          "enum": ["exact", "regex"]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "allowed_readers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/canonicalInterfaceName"
          },
          "uniqueItems": true
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadataMedium": {
      "type": "string",
      "enum": [
        "local-filesystem",
        "remote-filesystem",
        "network-request",
        "prompt",
        "stdin",
        "stdout",
        "stderr",
        "local-system"
      ]
    },
    "metadataAccess": {
      "type": "string",
      "enum": [
        "read",
        "write",
        "read-write",
        "execute",
        "configure",
        "request",
        "download",
        "upload",
        "send",
        "delete"
      ]
    },
    "metadataSystem": {
      "type": "string",
      "enum": [
        "filesystem",
        "google-calendar",
        "google-drive",
        "email-imap",
        "email-smtp",
        "weather-service",
        "arxiv",
        "web-search",
        "web-fetch",
        "model-cache",
        "systemd",
        "launchd",
        "task-scheduler",
        "cron",
        "system-log",
        "git",
        "shell",
        "browser",
        "local-http-server",
        "desktop-notification",
        "keyring",
        "oauth",
        "agent-runtime",
        "agent-home",
        "assistant-home",
        "tmux",
        "openai-api"
      ]
    },
    "metadataContent": {
      "type": "string",
      "enum": [
        "document",
        "source",
        "bibliography",
        "proof",
        "notation",
        "prose",
        "flow",
        "theorem",
        "argument",
        "docstring",
        "latex-project",
        "report",
        "graph",
        "plan",
        "plan-request",
        "list",
        "email",
        "email-attachment",
        "email-account",
        "message",
        "response",
        "attachment",
        "mailbox",
        "account",
        "credential",
        "environment-variable",
        "event",
        "forecast",
        "metadata",
        "log",
        "transcript",
        "watermark",
        "decision",
        "token",
        "config",
        "service",
        "timer",
        "job",
        "schedule",
        "checkpoint",
        "patch",
        "project",
        "repository",
        "profile",
        "hook",
        "launcher",
        "shell-profile",
        "path-entry",
        "symlink",
        "alias",
        "skill",
        "blueprint",
        "validator",
        "test-suite",
        "runtime-dependency-manifest",
        "generated-artifact",
        "installed-skill",
        "audit-record",
        "dependency-record",
        "drift-report",
        "hash",
        "macro-definitions",
        "sync-state",
        "filter",
        "diagnostic-report"
      ]
    },
    "metadataFormat": {
      "type": "string",
      "enum": [
        "text",
        "markdown",
        "html",
        "json",
        "yaml",
        "toml",
        "ini",
        "pdf",
        "tex",
        "bibtex",
        "svg",
        "png",
        "rfc822",
        "ics",
        "env",
        "stdout-text",
        "stderr-text"
      ]
    },
    "metadataAuthKind": {
      "type": "string",
      "enum": [
        "none",
        "google-calendar-oauth",
        "google-drive-oauth",
        "gmail-oauth",
        "email-account",
        "app-password",
        "rclone-config",
        "api-key",
        "keyring-entry",
        "local-user-session",
        "system-user",
        "agent-profile"
      ]
    },
    "metadataAuthMode": {
      "type": "string",
      "enum": [
        "none",
        "uses-existing",
        "creates",
        "updates",
        "deletes",
        "checks"
      ]
    },
    "metadataAuthRequirement": {
      "type": "object",
      "required": ["kind", "mode"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/metadataAuthKind"
        },
        "mode": {
          "$ref": "#/definitions/metadataAuthMode"
        }
      }
    },
    "metadataSensitivity": {
      "type": "string",
      "enum": [
        "public",
        "user-private",
        "secret",
        "derived-private"
      ]
    },
    "invocation": {
      "type": "object",
      "description": "How the dispatcher invokes this machine interface, plus non-code behavior sources read by that invocation.",
      "required": ["kind", "entrypoint", "behavior_sources"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "python_machine_interface"
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "pattern": "^_rtx/[A-Za-z_][A-Za-z0-9_]*\\.py:[A-Za-z_][A-Za-z0-9_]*$"
        },
        "args_prefix": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "behavior_sources": {
          "$ref": "#/definitions/behaviorSourceList"
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "min_positionals": {
          "type": "integer",
          "minimum": 0
        },
        "max_positionals": {
          "type": "integer",
          "minimum": 0
        },
        "allow_extra_positionals": {
          "type": "boolean",
          "default": false
        },
        "allow_stdin": {
          "type": "boolean",
          "default": false
        },
        "positional_patterns": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[0-9]+$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "flag_patterns": {
          "type": "object",
          "propertyNames": {
            "pattern": "^--[A-Za-z0-9][A-Za-z0-9-]*$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "allowed_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "forbidden_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "allowAllSkillsConstraint": {
      "if": {
        "properties": {
          "allow_all_skills": {
            "const": true
          }
        },
        "required": ["allow_all_skills"]
      },
      "then": {
        "properties": {
          "allowed_callers": {
            "maxItems": 0
          }
        }
      }
    }
  }
}
