{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Blueprint Schema",
  "description": "Schema for blueprint.yaml files that define skill contracts, dependencies, and interfaces.",
  "type": "object",
  "required": ["category", "interface_version"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "title": "Skill Category",
      "description": "One or more categories from references/skill-categories.md",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      ]
    },
    "interface_version": {
      "title": "Interface Version",
      "description": "Major version of the exported contract. Bump when breaking changes occur.",
      "type": "integer",
      "minimum": 1
    },
    "cross_platform": {
      "title": "Cross-Platform Validator Opt-In",
      "description": "Whether this skill is expected to satisfy the cross-platform validator. Omit or set true for the default shared-skill policy. Set false only for intentionally OS-bound skills, such as scheduler or service-manager integrations.",
      "type": "boolean",
      "default": true
    },
    "depends_on": {
      "title": "Dependencies",
      "description": "Map of skill name to dependency specification.",
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "major_version": {
                "type": "integer",
                "minimum": 1
              },
              "exports": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ]
      }
    },
    "skill_interface": {
      "title": "Skill Interface",
      "description": "High-level contract describing inputs, outputs, and side effects.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suggested_permissions": {
      "title": "Suggested Permissions",
      "description": "Permission suggestions for pre-approval.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bash": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "reason"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              },
              "args_prefix": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "reason"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": ["web_search", "web_fetch"]
              },
              "domains": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "script_interfaces": {
      "title": "Script Interfaces",
      "description": "Map of script-interface group name to invocation contract. Each group has one owner-facing default id plus optional named subinterfaces for narrower external views.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/scriptInterface"
      }
    }
  },
  "definitions": {
    "scriptInterface": {
      "type": "object",
      "required": ["id", "command"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable id of the owner-facing/default subinterface. This id must be unique within the skill. Uniqueness is enforced by skills/my-writing-skills/validators/interface_ids.py."
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Optional human-facing owner summary. When present, the sync tool injects this interface into SKILL.md. Omit it for narrow machine-facing subinterfaces that should stay out of the skill body."
        },
        "usage": {
          "type": "string",
          "description": "Optional complete invocation argument template (positionals, required flags, optional flags). The sync tool renders this into the dispatcher invocation in the generated SKILL.md block. Use \"\" for no-arg interfaces (renders clean invocation with no trailing args); omit entirely to render a '...' stub. Required whenever description is set."
        },
        "cwd": {
          "enum": ["skill_root", "repo_root"],
          "default": "skill_root"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/pattern"
          },
          "description": "Legacy/default shorthand for the owner-facing default subinterface. Prefer `default.patterns` for new blueprints."
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false,
          "description": "Legacy/default shorthand for the owner-facing default subinterface. Prefer `default.allow_all_skills` for new blueprints."
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Legacy/default shorthand for the owner-facing default subinterface. Prefer `default.allowed_callers` for new blueprints."
        },
        "default": {
          "$ref": "#/definitions/defaultSubinterface"
        },
        "subinterfaces": {
          "type": "object",
          "description": "Optional narrower callable views of the same script command. Use these to restrict other skills without affecting the owner-facing default surface.",
          "additionalProperties": {
            "$ref": "#/definitions/namedSubinterface"
          }
        }
      },
        "allOf": [
          {
            "$ref": "#/definitions/allowAllSkillsConstraint"
          }
        ]
    },
    "defaultSubinterface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/pattern"
          }
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "namedSubinterface": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable id of this named subinterface. Must be unique within the skill. Uniqueness is enforced by skills/my-writing-skills/validators/interface_ids.py."
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/pattern"
          }
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "min_positionals": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "max_positionals": {
          "type": "integer"
        },
        "allow_extra_positionals": {
          "type": "boolean",
          "default": false
        },
        "allow_stdin": {
          "type": "boolean",
          "default": false
        },
        "positional_patterns": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "flag_patterns": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "required_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "allowed_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "forbidden_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "allowAllSkillsConstraint": {
      "description": "If allow_all_skills is true, allowed_callers must be empty (public interface). If allow_all_skills is false, allowed_callers can be non-empty (restricted interface).",
      "if": {
        "properties": {
          "allow_all_skills": {
            "const": true
          }
        },
        "required": ["allow_all_skills"]
      },
      "then": {
        "properties": {
          "allowed_callers": {
            "maxItems": 0
          }
        }
      }
    }
  }
}
