{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Blueprint Schema",
  "description": "Schema for blueprint.yaml files that define skill contracts, dependencies, and interfaces.",
  "type": "object",
  "required": ["category", "interface_version", "interfaces"],
  "additionalProperties": false,
  "properties": {
    "category": {
      "type": "string",
      "enum": [
        "research-assistant",
        "general-assistant",
        "productivity-general-assistant",
        "workflow-general-assistant",
        "development-assistant",
        "skill-making-development-assistant",
        "coding-development-assistant",
        "system-assistant"
      ]
    },
    "interface_version": {
      "type": "integer",
      "minimum": 1
    },
    "cross_platform": {
      "type": "boolean",
      "default": true
    },
    "depends_on": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/skillName"
      },
      "additionalProperties": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "major_version": {
                "type": "integer",
                "minimum": 1
              },
              "exports": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "$ref": "#/definitions/canonicalInterfaceName"
                    },
                    {
                      "$ref": "#/definitions/interfaceName"
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    },
    "skill_interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suggested_permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bash": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "reason"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              },
              "args_prefix": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "reason"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": ["web_search", "web_fetch"]
              },
              "domains": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "interfaces": {
      "type": "object",
      "required": ["llm"],
      "additionalProperties": false,
      "properties": {
        "machine": {
          "$ref": "#/definitions/machineInterfaceMap"
        },
        "llm": {
          "$ref": "#/definitions/llmInterfaceMap"
        }
      }
    }
  },
  "definitions": {
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+$"
    },
    "interfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "canonicalInterfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+\\.(machine|llm)\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "machineInterfaceMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/interfaceName"
      },
      "additionalProperties": {
        "$ref": "#/definitions/machineInterface"
      }
    },
    "llmInterfaceMap": {
      "type": "object",
      "required": ["default"],
      "propertyNames": {
        "$ref": "#/definitions/interfaceName"
      },
      "additionalProperties": {
        "$ref": "#/definitions/llmInterface"
      }
    },
    "machineInterface": {
      "type": "object",
      "required": ["runtime", "dependencies", "directly_reads", "directly_executes", "directly_writes"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "usage": {
          "type": "string"
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/pattern"
          }
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/skillName"
          },
          "default": []
        },
        "runtime": {
          "$ref": "#/definitions/runtime"
        },
        "dependencies": {
          "$ref": "#/definitions/runtimeDependencies"
        },
        "uses_interfaces": {
          "$ref": "#/definitions/usedMachineInterfaceList"
        },
        "directly_reads": {
          "$ref": "#/definitions/directEffectList"
        },
        "directly_executes": {
          "$ref": "#/definitions/directEffectList"
        },
        "directly_writes": {
          "$ref": "#/definitions/directEffectList"
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "runtimeDependencies": {
      "type": "array",
      "description": "Required runtime packages or executables for this machine interface. Use [] when the interface has no non-stdlib runtime dependencies.",
      "items": {
        "$ref": "#/definitions/runtimeDependency"
      },
      "uniqueItems": true
    },
    "runtimeDependency": {
      "type": "object",
      "required": ["kind", "name", "reason"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["python", "binary"]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.+\\-\\[\\]]*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "llmInterface": {
      "type": "object",
      "required": ["description", "directly_reads", "directly_executes", "directly_writes"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "binding": {
          "$ref": "#/definitions/llmBinding"
        },
        "file": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "allow_all_skills": {
          "type": "boolean",
          "default": false
        },
        "allowed_callers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/skillName"
          },
          "default": []
        },
        "routing_hints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "uses_interfaces": {
          "$ref": "#/definitions/usedMachineInterfaceList"
        },
        "directly_reads": {
          "$ref": "#/definitions/directEffectList"
        },
        "directly_executes": {
          "$ref": "#/definitions/directEffectList"
        },
        "directly_writes": {
          "$ref": "#/definitions/directEffectList"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["binding"]
            },
            {
              "required": ["file"]
            }
          ]
        },
        {
          "$ref": "#/definitions/allowAllSkillsConstraint"
        }
      ]
    },
    "llmBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "path"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "skill_file"
            },
            "path": {
              "const": "SKILL.md"
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "path"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "markdown_file"
            },
            "path": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/).+"
            }
          }
        },
        {
          "type": "object",
          "required": ["kind", "uri"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "const": "uri"
            },
            "uri": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z][A-Za-z0-9+.-]*:.*$"
            }
          }
        }
      ]
    },
    "usedMachineInterfaceList": {
      "type": "array",
      "description": "Canonical machine interfaces this interface may use or orchestrate. These interface hashes are included recursively in this interface's audit hash.",
      "items": {
        "$ref": "#/definitions/canonicalMachineInterfaceName"
      },
      "uniqueItems": true
    },
    "canonicalMachineInterfaceName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)+\\.machine\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "directEffectList": {
      "type": "array",
      "description": "Direct file roots this interface reads, executes, or writes. Paths are relative to the directory containing blueprint.yaml, or may use $repo/ for repository-root relative paths. Use [] when there are no direct roots.",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
      },
      "uniqueItems": true
    },
    "runtime": {
      "type": "object",
      "required": ["kind", "entrypoint"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "python_machine_interface"
        },
        "entrypoint": {
          "type": "string",
          "minLength": 1,
          "pattern": "^_rtx/[A-Za-z_][A-Za-z0-9_]*\\.py:[A-Za-z_][A-Za-z0-9_]*$"
        },
        "args_prefix": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "min_positionals": {
          "type": "integer",
          "minimum": 0
        },
        "max_positionals": {
          "type": "integer",
          "minimum": 0
        },
        "allow_extra_positionals": {
          "type": "boolean",
          "default": false
        },
        "allow_stdin": {
          "type": "boolean",
          "default": false
        },
        "positional_patterns": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[0-9]+$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "flag_patterns": {
          "type": "object",
          "propertyNames": {
            "pattern": "^--[A-Za-z0-9][A-Za-z0-9-]*$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "allowed_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "forbidden_flags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^-{1,2}[A-Za-z0-9][A-Za-z0-9-]*$"
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "allowAllSkillsConstraint": {
      "if": {
        "properties": {
          "allow_all_skills": {
            "const": true
          }
        },
        "required": ["allow_all_skills"]
      },
      "then": {
        "properties": {
          "allowed_callers": {
            "maxItems": 0
          }
        }
      }
    }
  }
}
